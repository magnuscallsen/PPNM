set terminal pngcairo size 1000,800
set output "Eight_solution.png"

set title "Newtonian three-body figure-8 orbit"
set xlabel "x"
set ylabel "y"
set size ratio -1
set grid
set key outside

plot \
    "eight.data" using 2:3 with lines title "body 1", \
    "eight.data" using 4:5 with lines title "body 2", \
    "eight.data" using 6:7 with lines title "body 3"
